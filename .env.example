# -------------------------------------------------------
# Environment Variables
# -------------------------------------------------------
# -------------------------------------------------------
# Setup Instructions
# -------------------------------------------------------
# 1. Copy this file and rename it to `.env`
#    Example:
#    cp .env.example .env   (Mac/Linux)
#    copy .env.example .env (Windows)
#
# 2. Replace all placeholder values with your actual credentials
#
# 3. Ensure `.env` is NOT committed to Git
#    (already handled via .gitignore)
#
# 4. Validate setup:
#    dbt debug --target dev
#-------------------------
# dbt Target
# -------------------------
DBT_TARGET=dev # Options: dev | qa | prod

# -------------------------
# Dataset
# -------------------------
DBT_DATASET=dbt_starter_template# Base dataset name

# -------------------------
# GCP Project IDs
# -------------------------
DBT_GCP_PROJECT_DEV=your-dev-project-id 
# Development project ID
DBT_GCP_PROJECT_QA=your-qa-project-id 
# Quality Assurance project ID
DBT_GCP_PROJECT_PROD=your-prod-project-id 
# Production project ID

# -------------------------
# Service Account Keyfiles
# -------------------------
DBT_KEYFILE_DEV=/path/to/dev-service-account.json
DBT_KEYFILE_QA=/path/to/qa-service-account.json
DBT_KEYFILE_PROD=/path/to/prod-service-account.json

# -------------------------
# Threads
# -------------------------
# DEFAULT: 4 for dev/qa, 8 for prod (adjust based on your environment)
DBT_THREADS_DEV=4
DBT_THREADS_QA=4
DBT_THREADS_PROD=8