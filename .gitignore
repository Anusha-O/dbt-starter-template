# -------------------------------------------------------
# dbt .gitignore
# -------------------------------------------------------

# dbt compiled output — auto generated
target/

# dbt log files
logs/

# dbt installed packages — restored via dbt deps
dbt_packages/

# Environment variables — never commit real values
.env.local
.env

# Python virtual environments
venv/
dbt-env/

# OS files
.DS_Store
Thumbs.db

# IDE/editor settings
.vscode/
.idea/