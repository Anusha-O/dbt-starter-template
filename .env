# -------------------------------------------------------
# Environment Variables
# -------------------------------------------------------
# File name: .env
#
# ⚠️ WARNING:
# - Never commit this file with real values
# - This file is listed in .gitignore
# - Replace all placeholder values before use
#
# Usage:
# source .env
# dbt debug --target dev
# -------------------------------------------------------

# -------------------------
# dbt Target
# -------------------------
DBT_TARGET=dev

# -------------------------
# Dataset
# -------------------------
DBT_DATASET=dbt_starter_template

# -------------------------
# GCP Project IDs
# -------------------------
DBT_GCP_PROJECT_DEV=your-dev-project-id
DBT_GCP_PROJECT_QA=your-qa-project-id
DBT_GCP_PROJECT_PROD=your-prod-project-id

# -------------------------
# Service Account Keyfiles
# -------------------------
DBT_KEYFILE_DEV=/path/to/dev-service-account.json
DBT_KEYFILE_QA=/path/to/qa-service-account.json
DBT_KEYFILE_PROD=/path/to/prod-service-account.json

# -------------------------
# Threads
# -------------------------
DBT_THREADS_DEV=4
DBT_THREADS_QA=4
DBT_THREADS_PROD=8